{
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/cron/blog-trigger",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/blog-indexing",
      "schedule": "0 19 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
